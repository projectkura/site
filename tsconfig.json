{
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "strictNullChecks": true,
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "collections/*": ["./.source/*"],
      "~/*": ["./src/*"]
    }
  },
  "include": [".source", "source.config.ts", "src", "scripts"]
}
